# CoverIt DocGen environment
# Copy to .env when running coverit-docgen/docker.sh or DocGen locally.

# Application.
APP_NAME=DocGen
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=development
DOCGEN_TAG=dev

# External services.
# scripts/run_local_worker.py rewrites redis/api/neo4j Docker hostnames below
# to 127.0.0.1 so this file also works for local DocGen development.
REDIS_URL=redis://redis:6379
API_BASE_URL=http://api:3000/api/v1
INTERNAL_SERVICE_TOKEN=change-me-for-internal-services

# Neo4j.
NEO4J_URL=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
DOCGEN_NEO4J_URL=bolt://neo4j:7687
DOCGEN_NEO4J_USERNAME=neo4j

# Polling / generation behavior.
MAX_SESSIONS_PER_POLL=5
CONTEXT_DISTANCE_THRESHOLD=0.40
BDD_RETRY_DELAY_SECONDS=30
BDD_MAX_RETRIES=5
BDD_SPLIT_FEATURES=False
BDD_FEATURE_SIMILARITY_THRESHOLD=0.42
BDD_SINGLETON_MERGE_THRESHOLD=0.25
VIDEO_ACTION_SPEED=1.0
POLLER_CRON_HOURS=0,4,8,12,16,20
POLLER_CRON_MINUTES=0
JIRA_REPORT_CRON_MINUTES=*
JIRA_REPORT_POLL_BATCH_SIZE=3
FFMPEG_PATH=

# CORS.
ALLOWED_ORIGINS=["http://localhost:3000"]
