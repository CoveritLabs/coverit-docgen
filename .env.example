# CoverIt DocGen environment
# Copy to .env when running coverit-docgen/docker.sh or DocGen locally.

# Application.
APP_NAME=DocGen
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=development
DOCGEN_TAG=dev

# External services.
# scripts/run_local_worker.py rewrites redis/api/neo4j Docker hostnames below
# to 127.0.0.1 so this file also works for local DocGen development.
REDIS_URL=redis://redis:6379
API_BASE_URL=http://api:3000/api/v1
INTERNAL_SERVICE_TOKEN=change-me-for-internal-services

# Neo4j.
NEO4J_URL=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
DOCGEN_NEO4J_URL=bolt://neo4j:7687
DOCGEN_NEO4J_USERNAME=neo4j

# Polling / generation behavior.
MAX_SESSIONS_PER_POLL=5
CONTEXT_DISTANCE_THRESHOLD=0.40
BDD_RETRY_DELAY_SECONDS=30
BDD_MAX_RETRIES=5
BDD_SPLIT_FEATURES=False
BDD_FEATURE_SIMILARITY_THRESHOLD=0.42
BDD_SINGLETON_MERGE_THRESHOLD=0.25
VIDEO_RETRY_DELAY_SECONDS=30
VIDEO_MAX_RETRIES=5
VIDEO_OUTPUT_DIR=artifacts/videos
VIDEO_DEFAULT_WIDTH=1280
VIDEO_DEFAULT_HEIGHT=720
VIDEO_DEFAULT_FPS=30
VIDEO_ACTION_SPEED=1.0
VIDEO_RANDOM_SEED=42
VIDEO_WINDOW_SCALE=0.86
VIDEO_FOCUS_ZOOM=1.4
VIDEO_FOCUS_PADDING=18.0
VIDEO_REST_INTRO_SECONDS=0.20
VIDEO_ZOOM_IN_SECONDS=0.50
VIDEO_CURSOR_MOVE_SECONDS=0.55
VIDEO_ACTION_HOLD_SECONDS=0.15
VIDEO_ZOOM_OUT_SECONDS=0.65
VIDEO_REST_OUTRO_SECONDS=0.20
VIDEO_FOCUS_PAN_SECONDS=0.35
VIDEO_STICKY_CAMERA_ENABLED=True
VIDEO_STICKY_MAX_DISTANCE_PX=520.0
VIDEO_STICKY_MAX_AXIS_RATIO=0.55
VIDEO_CLICK_PRESS_FRAMES=5
VIDEO_CLICK_PRESS_SCALE_MIN=0.72
POLLER_CRON_HOURS=0,4,8,12,16,20
POLLER_CRON_MINUTES=0
JIRA_REPORT_CRON_MINUTES=*
JIRA_REPORT_POLL_BATCH_SIZE=3
FFMPEG_PATH=

# CORS.
ALLOWED_ORIGINS=["http://localhost:3000"]
